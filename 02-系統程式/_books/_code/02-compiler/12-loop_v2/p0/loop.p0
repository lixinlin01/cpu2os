print("=== 1. 測試 For 迴圈與 Continue ===");
arr = [0,0,0,0,0];

// 產生[0, 10, 20, 30, 40]
for(i = 0; i < 5; i = i + 1) {
    if (i == 2) {
        continue; // 跳過 20
    }
    arr[i] = i * 10;
}
print("過濾後的陣列:", arr);


print("=== 2. 測試 While 迴圈與 Break ===");
count = 0;
while (1) { // 無窮迴圈
    count = count + 1;
    if (count > 3) {
        break; // 超過 3 就提早跳出
    }
    print("While 執行第", count, "次");
}
print("跳出迴圈了！");